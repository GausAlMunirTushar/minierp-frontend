{
  "app": {
    "name": "Mini ERP",
    "short_name": "ERP",
    "version": "1.0.0"
  },
  "layout": {
    "module_bar": { "width": "80px" },
    "module_sidebar": { "width": "256px" },
    "topbar": { "height": "64px" }
  },
  "modules": [
    {
      "id": "main",
      "label": "dashboard",
      "icon": "LayoutDashboard",
      "path": "/dashboard",
      "order": 1,
      "enabled": true,
      "required_permissions": ["dashboard.view"],
      "config_file": "main-config.json",
      "has_sidebar": false,
      "contain_menus": ["dashboard"]
    },
    {
      "id": "products",
      "label": "products",
      "icon": "Package",
      "path": "/products",
      "order": 2,
      "enabled": true,
      "required_permissions": ["products.view"],
      "config_file": "products-config.json",
      "has_sidebar": false,
      "contain_menus": ["products"]
    },
    {
      "id": "sales",
      "label": "sales",
      "icon": "Receipt",
      "path": "/sales",
      "order": 3,
      "enabled": true,
      "required_permissions": ["sales.create"],
      "config_file": "sales-config.json",
      "has_sidebar": false,
      "contain_menus": ["sales"]
    },
    {
      "id": "roles",
      "label": "roles",
      "icon": "ShieldCheck",
      "path": "/roles",
      "order": 4,
      "enabled": true,
      "required_permissions": [],
      "config_file": "roles-config.json",
      "has_sidebar": false,
      "contain_menus": ["roles"],
      "admin_only": true
    }
  ]
}
